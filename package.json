{
  "name": "paralax-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "ontology:graph": "node scripts/validate-ontology-graph.mjs",
    "prebuild": "npm run ontology:graph",
    "build": "next build && node scripts/crawl-guard.mjs",
    "start": "next start",
    "lint": "next lint",
    "smoke": "bash scripts/smoke-check.sh",
    "gsc:check": "bash scripts/gsc-check.sh",
    "vercel:status": "bash scripts/vercel-status.sh",
    "indexnow": "node scripts/ping-indexnow.mjs",
    "indexnow:all": "node scripts/ping-indexnow.mjs --all"
  },
  "dependencies": {
    "@editorialkit/schema": "file:packages/editorialkit-schema-1.1.1.tgz",
    "gray-matter": "^4.0.3",
    "next": "^15.5.18",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vercel": "^50.32.5"
  }
}
